# ~/.codex/rules/default.rules
# Codex Rules (Starlark)
# Goal: Prefer standard Git and GitHub CLI workflow, and block Graphite.

# Shell scripts can hide complex side effects, so require explicit approval.
prefix_rule(
    pattern = [["bash", "sh", "zsh"], ["-lc", "-c"]],
    decision = "prompt",
    justification = "Shell script execution may include hidden side effects.",
    match = [
        "bash -lc 'echo hello'",
        "sh -c 'cat <<EOF > /tmp/a.txt\nx\nEOF'",
    ],
)

# Hard block: Graphite is not part of the standard workflow.
prefix_rule(
    pattern = ["gt"],
    decision = "forbidden",
    justification = "Graphite commands are not used in this repository. Use standard git and gh workflow.",
    match = [
        "gt state",
        "gt checkout main",
        "gt create --message 'docs: update default rules'",
        "gt submit --no-interactive",
    ],
)

# Standard Git operations are allowed.
prefix_rule(
    pattern = ["git"],
    decision = "allow",
    justification = "Standard git operations are allowed for normal repository workflow.",
    match = [
        "git status",
        "git diff",
        "git log --oneline",
        "git show HEAD",
        "git branch",
        "git checkout feature-branch",
        "git switch -c docs/update-rules",
        "git add -A",
        "git restore --staged .",
        "git commit -m 'docs: update codex rules'",
        "git fetch origin",
        "git pull --ff-only",
        "git push origin feature-branch",
        "git rebase origin/main",
        "git merge origin/main",
        "git stash",
        "git cherry-pick abc1234",
    ],
)

# Hard block: destructive git operations.
prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Destructive git reset is not allowed without explicit approval.",
    match = [
        "git reset --hard",
        "git reset --hard HEAD~1",
    ],
)

prefix_rule(
    pattern = ["git", "clean"],
    decision = "forbidden",
    justification = "Destructive git clean is not allowed without explicit approval.",
    match = [
        "git clean -fd",
        "git clean -fdx",
    ],
)

prefix_rule(
    pattern = ["git", "push", "--force"],
    decision = "forbidden",
    justification = "Force push is not allowed without explicit approval.",
    match = [
        "git push --force origin feature-branch",
    ],
)

prefix_rule(
    pattern = ["git", "push", "--force-with-lease"],
    decision = "forbidden",
    justification = "Force push is not allowed without explicit approval.",
    match = [
        "git push --force-with-lease origin feature-branch",
    ],
)

prefix_rule(
    pattern = ["git", "push", "origin", "main"],
    decision = "forbidden",
    justification = "Direct pushes to main are not allowed.",
    match = [
        "git push origin main",
    ],
)

# Standard GitHub CLI operations are allowed.
prefix_rule(
    pattern = ["gh"],
    decision = "allow",
    justification = "Standard GitHub CLI operations are allowed for repository workflow.",
    match = [
        "gh auth status",
        "gh repo view --json nameWithOwner,defaultBranchRef",
        "gh pr status",
        "gh pr view 147 --json title,body,url",
        "gh pr create --title 'docs: update codex rules' --body-file /tmp/pr-body.md",
        "gh pr edit 147 --title 'docs: update codex rules'",
        "gh api repos/tonny-lec/booking_payment/pulls/147/comments --paginate",
    ],
)

# Hard block: destructive GitHub repository operations.
prefix_rule(
    pattern = ["gh", "repo", "delete"],
    decision = "forbidden",
    justification = "Repository deletion is not allowed.",
    match = [
        "gh repo delete tonny-lec/booking_payment",
    ],
)

# Safe utility commands.
prefix_rule(
    pattern = ["rg"],
    decision = "allow",
    justification = "ripgrep is safe for search.",
    match = [
        "rg -n TODO .",
    ],
)

prefix_rule(
    pattern = ["mkdir"],
    decision = "allow",
    justification = "mkdir is safe.",
    match = [
        "mkdir -p /tmp/work",
    ],
)

prefix_rule(
    pattern = ["cat"],
    decision = "allow",
    justification = "cat is safe.",
    match = [
        "cat README.md",
    ],
)

prefix_rule(
    pattern = ["ls"],
    decision = "allow",
    justification = "ls is safe.",
    match = [
        "ls -la",
    ],
)
