# ~/.codex/rules/default.rules
# Codex Rules (Starlark)
# Goal: Block git/gh usage and prefer Graphite workflow.

# Shell scripts can hide complex side effects, so require explicit approval.
prefix_rule(
    pattern = [["bash", "sh", "zsh"], ["-lc", "-c"]],
    decision = "prompt",
    justification = "Shell script execution may include hidden side effects.",
    match = [
        "bash -lc 'echo hello'",
        "sh -c 'cat <<EOF > /tmp/a.txt\nx\nEOF'",
    ],
)

# Hard block: git is forbidden.
prefix_rule(
    pattern = ["git"],
    decision = "forbidden",
    justification = "git commands are prohibited in this environment. Use Graphite (gt) workflow.",
    match = [
        "git status",
        "git add -A",
        "git commit -m 'wip'",
        "git push origin main",
    ],
)

# Graphite local workflow commands.
prefix_rule(
    pattern = ["gt", ["state", "checkout", "up", "down", "sync", "restack", "create", "modify"]],
    decision = "allow",
    justification = "Graphite commands are the default workflow for local stack management.",
    match = [
        "gt state",
        "gt checkout main",
        "gt sync",
        "gt create --message 'docs: update default rules'",
        "gt modify",
    ],
)

# Submitting a stack updates remote state: require confirmation.
prefix_rule(
    pattern = ["gt", "submit"],
    decision = "allow",
    justification = "Submitting a stack has remote side effects.",
    match = [
        "gt submit --no-interactive",
    ],
)

# Safe utility commands.
prefix_rule(
    pattern = ["rg"],
    decision = "allow",
    justification = "ripgrep is safe for search.",
    match = [
        "rg -n TODO .",
    ],
)

prefix_rule(
    pattern = ["mkdir"],
    decision = "allow",
    justification = "mkdir is safe.",
    match = [
        "mkdir -p /tmp/work",
    ],
)

prefix_rule(
    pattern = ["cat"],
    decision = "allow",
    justification = "cat is safe.",
    match = [
        "cat README.md",
    ],
)

prefix_rule(
    pattern = ["ls"],
    decision = "allow",
    justification = "ls is safe.",
    match = [
        "ls -la",
    ],
)

# Allow: PRの閲覧（コメント含む）
prefix_rule(
  pattern = ["gh", "pr", "view"],
  decision = "allow",
  justification = "Allow reading PR summary and comments for review triage",
  match = [
      "gh pr view 116 --repo tonny-lec/booking_payment --comments",
      "gh pr view 91 --repo tonny-lec/booking_payment --json title,body,comments",
  ],
  not_match = [
      "gh pr list --repo tonny-lec/booking_payment",
  ],
)

# Allow: GitHub APIでレビューコメント取得
prefix_rule(
  pattern = ["gh", "api"],
  decision = "allow",
  justification = "Allow fetching review comments/reviews from GitHub API",
  match = [
      "gh api repos/tonny-lec/booking_payment/pulls/116/comments --paginate",
      "gh api repos/tonny-lec/booking_payment/pulls/116/reviews --paginate",
  ],
  not_match = [
      "gh pr view 116 --repo tonny-lec/booking_payment",
  ],
)
